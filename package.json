{
  "author": "Jared Dellitt @jareddellitt",
  "bin": {
    "brale": "./bin/run.js"
  },
  "dependencies": {
    "@oclif/core": "3.15.0",
    "@oclif/plugin-help": "6.0.8",
    "@oclif/plugin-plugins": "^4",
    "axios": "^1.6.2",
    "openapi-client-axios": "^7.4.0"
  },
  "description": "Brale API CLI",
  "devDependencies": {
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^3",
    "@types/chai": "^4",
    "@types/mocha": "10.0.6",
    "@types/node": "20.10.4",
    "chai": "^4",
    "eslint": "^8.55.0",
    "eslint-config-oclif": "^5",
    "eslint-config-oclif-typescript": "3.0.26",
    "eslint-config-prettier": "9.1.0",
    "mocha": "^10",
    "oclif": "4.1.0",
    "shx": "0.3.4",
    "ts-node": "^10.9.2",
    "typescript": "5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "/bin",
    "/dist",
    "/oclif.manifest.json"
  ],
  "homepage": "https://github.com/Brale-xyz/brale-cli",
  "license": "MIT",
  "main": "dist/index.js",
  "name": "brale",
  "oclif": {
    "bin": "brale",
    "dirname": "brale",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins"
    ],
    "topicSeparator": " ",
    "topics": {
      "hello": {
        "description": "Say hello to the world and others"
      }
    }
  },
  "repository": "Brale-xyz/brale-cli",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "lint": "eslint . --ext .ts",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "yarn lint",
    "prepack": "yarn build && oclif manifest && oclif readme",
    "prepare": "yarn build",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md"
  },
  "version": "0.0.0",
  "bugs": "https://github.com/Brale-xyz/brale-cli/issues",
  "keywords": [
    "oclif"
  ],
  "types": "dist/index.d.ts"
}
